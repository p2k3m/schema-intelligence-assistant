# Optional AWS configuration for future Bedrock-backed embeddings or review routing.
# Do not commit real credentials. Prefer AWS_PROFILE or the default AWS credential chain.
AWS_REGION=us-east-1
AWS_PROFILE=default
AWS_BEDROCK_MODEL_ID=amazon.titan-embed-text-v2:0
USE_AWS_BEDROCK=false
SCHEMA_ASSISTANT_EMBEDDING_BACKEND=tfidf
SCHEMA_ASSISTANT_TEST_SENTENCE_TRANSFORMERS=false
SCHEMA_ASSISTANT_USE_OLLAMA=false
SCHEMA_ASSISTANT_AB_USE_OLLAMA=false
SCHEMA_ASSISTANT_OLLAMA_MODEL=llama3.2:1b
